# ============================================================
#  EXAMPLE ENVIRONMENT FILE  (safe to commit — no real secrets)
# ============================================================
# HOW TO USE:
#   1. Copy this file to a new file named  .env
#   2. Fill in real values for the blank settings below
#   3. NEVER commit the real .env  (it is git-ignored)
#
# Do NOT put real passwords or secrets in this example file.

# Port the local server listens on.
PORT=3000

# Environment: "development" locally, "production" on the VPS.
# In production the admin session cookie is marked Secure (HTTPS only).
NODE_ENV=development

# Password for the admin panel login. REQUIRED — the server will not start
# without it. Choose a strong value in your real .env.
ADMIN_PASSWORD=

# Long random string used to sign the admin session cookie. REQUIRED — the
# server will not start without it. Use a long, unpredictable value.
SESSION_SECRET=
