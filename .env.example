# ============================================================
#  EXAMPLE ENVIRONMENT FILE  (safe to commit — no real secrets)
# ============================================================
# HOW TO USE (in a later stage, when the server is built):
#   1. Copy this file to a new file named  .env
#   2. Replace every placeholder below with a real value
#   3. NEVER commit the real .env  (it is git-ignored)
#
# These are placeholder names only. Do NOT put real passwords here.

# Password for the admin panel login.
ADMIN_PASSWORD=your_admin_password_here

# Long random string used to sign the admin session cookie.
SESSION_SECRET=your_long_random_session_secret_here

# Port the local server will listen on.
PORT=3000

# Environment: "development" locally, "production" on the VPS.
# In production the session cookie is marked Secure (HTTPS only).
NODE_ENV=development
